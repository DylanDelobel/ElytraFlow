{
  "schemaVersion": 1,
  "id": "elytraflow",
  "version": "${version}",
  "name": "ElytraFlow",
  "description": "Automatically swaps your elytra back to your best chestplate when you land.",
  "authors": ["Sovex66"],
  "contact": {
    "homepage": "https://modrinth.com/mod/elytraflow",
    "issues": "https://github.com/DylanDelobel/ElytraFlow/issues"
  },
  "license": "MIT",
  "icon": "assets/elytraflow/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": ["com.elytraflow.fabric.ElytraFlowFabric"]
  },
  "mixins": ["elytraflow.mixins.json"],
  "depends": {
    "fabricloader": ">=0.19.3",
    "fabric-api": "*",
    "minecraft": "~26.2",
    "java": ">=21"
  }
}
